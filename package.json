{
  "name": "syntreature",
  "version": "1.0.0",
  "description": "Autonomous AI agent for gasless NL trading escrow with GMX integration",
  "license": "GPL-3.0",
  "private": true,
  "scripts": {
    "chain": "hardhat node --network hardhat",
    "fork:status": "hardhat node --network hardhat --fork https://public.sepolia.rpc.status.network",
    "fork:arbitrum": "hardhat node --network hardhat --fork https://arb-sepolia.g.alchemy.com/v2/$ALCHEMY_API_KEY",
    "compile": "hardhat compile",
    "deploy:status": "hardhat run scripts/deploy.ts --network statusSepolia",
    "deploy:arbitrum": "hardhat run scripts/deployArbitrum.ts --network arbitrumSepolia",
    "test": "hardhat test",
    "test:fork:status": "hardhat test --network hardhat --fork https://public.sepolia.rpc.status.network",
    "test:fork:arbitrum": "hardhat test --network hardhat --fork https://arb-sepolia.g.alchemy.com/v2/$ALCHEMY_API_KEY",
    "typechain": "typechain --target ethers-v6 --out-dir typechain-types './abi/**/*.json'",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,sol,json,md}\"",
    "dev": "next dev",
    "build:next": "next build",
    "start": "next start",
    "export": "next export"
  },
  "dependencies": {
    "@ethersproject/abi": "^5.7.0",
    "@ethersproject/address": "^5.7.0",
    "@ethersproject/bignumber": "^5.7.0",
    "@ethersproject/bytes": "^5.7.0",
    "@ethersproject/constants": "^5.7.0",
    "@ethersproject/contracts": "^5.7.0",
    "@ethersproject/providers": "^5.7.0",
    "@ethersproject/signers": "^5.7.0",
    "@ethersproject/units": "^5.7.0",
    "@ethersproject/wallet": "^5.7.0",
    "@next/font": "^14.0.3",
    "@rainbow-me/rainbowkit": "^2.1.2",
    "axios": "^1.6.0",
    "ethers": "^6.7.1",
    "next": "^14.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@solidity-parser/parser": "^0.17.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "chai": "^4.3.7",
    "dotenv": "^16.0.3",
    "eslint": "^8.0.0",
    "ethers": "^6.7.1",
    "hardhat": "^2.19.0",
    "hardhat-deploy": "^0.12.0",
    "hardhat-gas-reporter": "^1.0.8",
    "prettier": "^3.0.0",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.1",
    "typechain": "^8.3.1",
    "typescript": "^5.0.0"
  }
}
